{
  "manifest_version": 3,
  "name": "Deezer BPM",
  "version": "1.0",
  "description": "Shows the BPM of the currently playing song on Deezer",
  "icons": {
    "48": "icons/icon48.svg"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.deezer.com/*",
    "https://api.deezer.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{daa6e7d2-9aaf-4898-89a4-0f7224841a44}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.deezer.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
